// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id               String    @id @default(uuid())
  nombre           String
  email            String    @unique
  telefono         String?
  fuente           String    
  producto_interes String?   @map("producto_interes")
  presupuesto      Float?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime? 

  @@map("leads")
}