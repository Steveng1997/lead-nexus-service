datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model Lead {
  id               String    @id @default(uuid())
  nombre           String
  email            String    @unique
  fuente           String
  producto_interes String
  presupuesto      Float?
  telefono         String?
  createdAt        DateTime  @default(now()) @map("created_at") // Mapea CamelCase a SnakeCase
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  @@map("leads")
}
